{
  "name": "@andrewmcodes/js-configs",
  "version": "0.0.0",
  "private": true,
  "description": "JavaScript Tooling Configuration Monorepo",
  "license": "MIT",
  "author": "Andrew Mason (https://andrewm.codes)",
  "homepage": "https://github.com/andrewmcodes/js-configs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewmcodes/js-configs.git"
  },
  "bugs": "https://github.com/andrewmcodes/js-configs/issues",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm lint && pnpm test && pnpm typecheck",
    "publish:all": "pnpm -r publish",
    "version": "auto version",
    "release": "pnpm build && auto shipit"
  },
  "devDependencies": {
    "@auto-it/conventional-commits": "^11.3.0",
    "@auto-it/npm": "^11.3.0",
    "@auto-it/released": "^11.3.0",
    "@types/node": "^24.6.2",
    "auto": "^11.3.0",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.18.0"
}
